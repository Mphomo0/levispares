{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    },
    "convex": {
      "type": "local",
      "command": [
        "npx",
        "convex@latest",
        "mcp",
        "start",
        "--project-dir",
        "."
      ],
      "enabled": true
    }
  }
}
